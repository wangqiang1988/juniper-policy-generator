{# Jinja2 template for SRX `set` commands. Each `set` line is on its own line. -#}
# === Auto-generated by juniper-policy-generator at {{ timestamp }} ===
# Policy: {{ policy.name }}
{% if policy.description -%}
# Description: {{ policy.description }}
{% endif -%}
{% if addresses -%}
# === Address objects ===
{% for addr in addresses -%}
set security address-book global address {{ addr.name }} {{ addr.value }}
{% endfor -%}
{% endif -%}
{% if applications -%}
# === Applications ===
{% for app in applications -%}
set applications application {{ app.name }} protocol {{ app.protocol }} destination-port {{ app.port_spec }}
{% endfor -%}
{% endif -%}
# === Policy ===
set security policies from-zone {{ policy.from_zone }} to-zone {{ policy.to_zone }} policy {{ policy.name }}{% if policy.description %} description "{{ policy.description }}"{% endif %}

{% for src in policy.source_addresses -%}
set security policies from-zone {{ policy.from_zone }} to-zone {{ policy.to_zone }} policy {{ policy.name }} match source-address {{ src }}
{% endfor -%}
{% for dst in policy.destination_addresses -%}
set security policies from-zone {{ policy.from_zone }} to-zone {{ policy.to_zone }} policy {{ policy.name }} match destination-address {{ dst }}
{% endfor -%}
{% for app in policy.applications -%}
set security policies from-zone {{ policy.from_zone }} to-zone {{ policy.to_zone }} policy {{ policy.name }} match application {{ app }}
{% endfor -%}
set security policies from-zone {{ policy.from_zone }} to-zone {{ policy.to_zone }} policy {{ policy.name }} then {{ policy.action }}
# === END ===
